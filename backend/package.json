{
  "name": "tiburcio-backend",
  "version": "2.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "check": "biome check src/ && tsc --noEmit",
    "mcp": "node dist/mcp.js",
    "mcp:dev": "tsx src/mcp.ts",
    "index:standards": "tsx ./scripts/index-standards.ts",
    "index:codebase": "tsx ./scripts/index-codebase.ts",
    "index:architecture": "tsx ./scripts/index-architecture.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/openai-compatible": "^2.0.30",
    "@ai-sdk/provider": "^3.0.8",
    "@hono/node-server": "^1.19.9",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "@qdrant/js-client-rest": "^1.17.0",
    "ai": "^6.0.94",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.69.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.0",
    "hono-pino": "^0.10.3",
    "hono-rate-limiter": "^0.5.3",
    "ioredis": "^5.9.3",
    "neo4j-driver": "^6.0.1",
    "ollama-ai-provider": "^1.2.0",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.5",
    "tree-sitter": "^0.22.4",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-typescript": "^0.23.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.31.9",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
