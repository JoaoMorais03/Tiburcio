# Tiburcio backend — environment variables
# Copy to .env and fill in your values.
# Only MODEL_PROVIDER, DATABASE_URL, and JWT_SECRET are required.

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://tiburcio:tiburcio@localhost:5432/tiburcio

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_SECRET=change-me-to-at-least-32-random-characters!!

# ─── Model Provider ───────────────────────────────────────────────────────────
# "ollama" (default, local) or "openai-compatible" (vLLM, OpenRouter, LM Studio, etc.)
MODEL_PROVIDER=ollama

# Ollama settings (used when MODEL_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# OpenAI-compatible settings (required when MODEL_PROVIDER=openai-compatible)
# INFERENCE_BASE_URL=https://openrouter.ai/api/v1
# INFERENCE_API_KEY=sk-or-...
# INFERENCE_MODEL=minimax/minimax-m2.5
# INFERENCE_EMBEDDING_MODEL=qwen/qwen3-embedding-8b

# Embedding vector dimensions: auto-detected from MODEL_PROVIDER (768 Ollama / 4096 openai-compatible).
# Override only if your model differs from the defaults.
# EMBEDDING_DIMENSIONS=768

# ─── Infrastructure ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333

# ─── Codebase Indexing ─────────────────────────────────────────────────────────
# Format: name:absolute-path:branch  (comma-separated for multiple repos)
# CODEBASE_REPOS=myproject:/path/to/repo:main
# CODEBASE_REPOS=api:/repos/api:develop,ui:/repos/ui:main

# ─── MCP HTTP/SSE Transport ────────────────────────────────────────────────────
# Required to expose MCP over HTTP for team deployment (GET /mcp).
# Leave unset to disable HTTP/SSE — stdio transport still works without it.
# TEAM_API_KEY=your-team-secret-key

# ─── Observability (optional) ──────────────────────────────────────────────────
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
